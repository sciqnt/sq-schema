{
  "$defs": {
    "Account": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "base_currency": {
          "title": "Base Currency",
          "type": "string"
        },
        "broker": {
          "title": "Broker",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "account_id",
        "broker",
        "base_currency"
      ],
      "title": "Account",
      "type": "object"
    },
    "AssetClass": {
      "description": "Cross-asset classification. String-valued so JSON-stable.\nAdd new values; never repurpose existing ones.",
      "enum": [
        "STOCK",
        "ETF",
        "BOND",
        "FUND",
        "OPTION",
        "FUTURE",
        "FX",
        "CRYPTO",
        "CASH",
        "INDEX",
        "WARRANT",
        "CFD",
        "EVENT",
        "OTHER"
      ],
      "title": "AssetClass",
      "type": "string"
    },
    "Bitemporal": {
      "additionalProperties": false,
      "description": "Every entity in sq_schema inherits this. Two timestamps, both required.",
      "properties": {
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "title": "Bitemporal",
      "type": "object"
    },
    "CashBalance": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "amount_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount Base"
        },
        "currency": {
          "title": "Currency",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "account_id",
        "currency",
        "amount"
      ],
      "title": "CashBalance",
      "type": "object"
    },
    "ClosedLot": {
      "additionalProperties": false,
      "description": "One matched portion of a SELL against a specific acquisition lot.",
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "closed_at": {
          "format": "date-time",
          "title": "Closed At",
          "type": "string"
        },
        "cost_basis_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Cost Basis Base"
        },
        "cost_per_unit_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Cost Per Unit Local"
        },
        "fx_at_acquisition": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Fx At Acquisition"
        },
        "fx_at_sell": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Fx At Sell"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "opened_at": {
          "format": "date-time",
          "title": "Opened At",
          "type": "string"
        },
        "proceeds_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Proceeds Base"
        },
        "proceeds_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Proceeds Local"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "realized_currency_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Realized Currency Pl Base"
        },
        "realized_fees_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Realized Fees Base"
        },
        "realized_product_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Realized Product Pl Base"
        },
        "sell_price_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Sell Price Local"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "account_id",
        "instrument_id",
        "opened_at",
        "closed_at",
        "quantity",
        "cost_per_unit_local",
        "fx_at_acquisition",
        "cost_basis_base",
        "sell_price_local",
        "fx_at_sell",
        "proceeds_local",
        "proceeds_base",
        "realized_product_pl_base",
        "realized_currency_pl_base",
        "realized_fees_base"
      ],
      "title": "ClosedLot",
      "type": "object"
    },
    "FxRate": {
      "additionalProperties": false,
      "properties": {
        "from_currency": {
          "title": "From Currency",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Rate"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "to_currency": {
          "title": "To Currency",
          "type": "string"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "from_currency",
        "to_currency",
        "rate",
        "source"
      ],
      "title": "FxRate",
      "type": "object"
    },
    "Instrument": {
      "additionalProperties": false,
      "properties": {
        "asset_class": {
          "$ref": "#/$defs/AssetClass"
        },
        "identifiers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Identifiers",
          "type": "object"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "listing_currency": {
          "title": "Listing Currency",
          "type": "string"
        },
        "listing_venue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Listing Venue"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "terms": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Terms"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "instrument_id",
        "identifiers",
        "name",
        "asset_class",
        "listing_currency"
      ],
      "title": "Instrument",
      "type": "object"
    },
    "NewsItem": {
      "additionalProperties": false,
      "description": "One headline. `valid_at` is the publish time the source reports\n(fetch time when the source omits it \u2014 declared per provider).",
      "properties": {
        "headline": {
          "title": "Headline",
          "type": "string"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "ticker": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ticker"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "headline",
        "source"
      ],
      "title": "NewsItem",
      "type": "object"
    },
    "PortfolioSnapshot": {
      "additionalProperties": false,
      "properties": {
        "account": {
          "$ref": "#/$defs/Account"
        },
        "cash_balances": {
          "items": {
            "$ref": "#/$defs/CashBalance"
          },
          "title": "Cash Balances",
          "type": "array"
        },
        "instruments": {
          "items": {
            "$ref": "#/$defs/Instrument"
          },
          "title": "Instruments",
          "type": "array"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "positions": {
          "items": {
            "$ref": "#/$defs/Position"
          },
          "title": "Positions",
          "type": "array"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "account",
        "instruments",
        "positions",
        "cash_balances"
      ],
      "title": "PortfolioSnapshot",
      "type": "object"
    },
    "Position": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "break_even_price_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Break Even Price Local"
        },
        "cost_basis_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Cost Basis Base"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "last_price_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Price Local"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "realized_currency_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Realized Currency Pl Base"
        },
        "realized_fees_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Realized Fees Base"
        },
        "realized_product_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Realized Product Pl Base"
        },
        "unrealized_currency_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Unrealized Currency Pl Base"
        },
        "unrealized_product_pl_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Unrealized Product Pl Base"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        },
        "value_base": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Value Base"
        }
      },
      "required": [
        "account_id",
        "instrument_id",
        "quantity"
      ],
      "title": "Position",
      "type": "object"
    },
    "Price": {
      "additionalProperties": false,
      "description": "A market price observation: `last_price_local` units of `currency`\nper unit of the underlying instrument, observed `valid_at`.",
      "properties": {
        "currency": {
          "title": "Currency",
          "type": "string"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "last_price_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Last Price Local"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "last_price_local",
        "currency",
        "source"
      ],
      "title": "Price",
      "type": "object"
    },
    "Transaction": {
      "additionalProperties": false,
      "description": "One immutable event affecting the portfolio.",
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "amount_currency": {
          "title": "Amount Currency",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "executed_at": {
          "format": "date-time",
          "title": "Executed At",
          "type": "string"
        },
        "fee": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fee"
        },
        "fx_rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fx Rate"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "price_local": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price Local"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quantity"
        },
        "related_transaction_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Related Transaction Ids",
          "type": "array"
        },
        "transaction_id": {
          "title": "Transaction Id",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/TransactionType"
        },
        "valid_at": {
          "format": "date-time",
          "title": "Valid At",
          "type": "string"
        }
      },
      "required": [
        "transaction_id",
        "account_id",
        "type",
        "executed_at",
        "amount",
        "amount_currency"
      ],
      "title": "Transaction",
      "type": "object"
    },
    "TransactionType": {
      "description": "The kind of event a Transaction represents. String-valued so JSON-stable.\nAdd new values; never repurpose existing ones.",
      "enum": [
        "BUY",
        "SELL",
        "DIVIDEND",
        "DIVIDEND_REINVEST",
        "FEE",
        "TAX",
        "INTEREST",
        "DEPOSIT",
        "WITHDRAWAL",
        "FX_EXCHANGE",
        "SPLIT",
        "SPIN_OFF",
        "MERGER",
        "SETTLEMENT",
        "OTHER"
      ],
      "title": "TransactionType",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sciqnt canonical contract",
  "x-sciqnt-contract-version": "0.1.0"
}
